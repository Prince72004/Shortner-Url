<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>

    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Segoe UI", sans-serif;
        }

        body{
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #667eea, #764ba2);
        }

        .container{
            width: 90%;
            max-width: 550px;
            background: white;
            padding: 35px;
            border-radius: 18px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        }

        h1{
            text-align: center;
            margin-bottom: 25px;
            color: #333;
        }

        .subtitle{
            text-align: center;
            color: #777;
            margin-bottom: 25px;
            font-size: 14px;
        }

        input{
            width: 100%;
            padding: 14px;
            border: 2px solid #ddd;
            border-radius: 10px;
            font-size: 15px;
            outline: none;
            transition: 0.3s;
        }

        input:focus{
            border-color: #667eea;
        }

        button{
            width: 100%;
            margin-top: 15px;
            padding: 14px;
            border: none;
            border-radius: 10px;
            background: #667eea;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover{
            background: #5563d8;
        }

        .result{
            margin-top: 25px;
            padding: 18px;
            border-radius: 10px;
            background: #f5f7ff;
            border-left: 5px solid #667eea;
        }

        .result h3{
            margin-bottom: 10px;
            color: #333;
        }

        .result a{
            color: #667eea;
            text-decoration: none;
            word-break: break-all;
            font-weight: 500;
        }

        .result a:hover{
            text-decoration: underline;
        }
    </style>
</head>

<body>

    <div class="container">

        <h1>🔗 URL Shortener</h1>

        <p class="subtitle">
            Paste your long URL and get a short link instantly
        </p>

        <form action="/url" method="POST">
            <input
                type="url"
                name="redirecturl"
                placeholder="https://example.com"
                required
            />

            <button type="submit">
                Shorten URL
            </button>
        </form>

        <% if(typeof shortId !== 'undefined') { %>
            <div class="result">
                <h3>Your Short URL</h3>

                <a href="/url/<%= shortId %>" target="_blank">
                    <%= baseUrl %>/url/<%= shortId %>
                </a>
            </div>
        <% } %>

    </div>

</body>
</html>